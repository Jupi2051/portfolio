generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String
  password  String
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  description String
  content     String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model PinnedMessage {
  id        String   @id @default(cuid())
  content   String
  author    String
  color     String
  positionX Int
  positionY Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model VicoSketch {
  id        String   @id @default(cuid())
  
  approved Boolean @default(false)
  title String
  author String
  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  image VicoSketchImage?
}

model VicoSketchImage {
  id        String   @id @default(cuid())
  data      Bytes    @db.ByteA
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sketchId String @unique
  sketch VicoSketch @relation(fields: [sketchId], references: [id])
}